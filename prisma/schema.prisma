generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model accounts {
  id                String  @id @default(uuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  users             users   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model activity_logs {
  id          String         @id
  userId      String
  action      ActivityAction
  entityType  String
  entityId    String
  metadata    Json?
  title       String
  description String?
  createdAt   DateTime       @default(now())
  users       users          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([createdAt])
  @@index([entityType, entityId])
  @@index([userId])
}

model admins {
  id            String   @id
  name          String?
  email         String   @unique
  password       String
  smtpHost       String?
  smtpPort       String?   @default("587")
  smtpSecure     Boolean  @default(false)
  smtpUser       String?
  smtpPass       String?
  smtpFromName   String?  @default("NotaBener")
  smtpFromEmail   String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime
  impersonation_sessions impersonation_sessions[]
}

model analytics_snapshots {
  id               String   @id
  teamId           String?
  userId           String?
  date             DateTime
  revenue          Float    @default(0)
  revenueYtd       Float    @default(0)
  invoicesCreated  Int      @default(0)
  invoicesSent     Int      @default(0)
  invoicesPaid     Int      @default(0)
  invoicesOverdue  Int      @default(0)
  newClients       Int      @default(0)
  activeClients    Int      @default(0)
  paymentsReceived Int      @default(0)
  paymentsAmount   Float    @default(0)
  paymentsFailed   Int      @default(0)
  conversionRate   Float    @default(0)
  periodType       String   @default("daily")
  createdAt        DateTime @default(now())

  @@unique([teamId, userId, date, periodType])
  @@index([teamId, date])
  @@index([userId, date])
}

model api_keys {
  id            String    @id
  userId        String?
  teamId        String?
  name          String
  key           String    @unique
  prefix        String
  scopes        Json?
  permissions   Json?
  rateLimit     Int       @default(1000)
  rateLimitUsed Int       @default(0)
  isActive      Boolean   @default(true)
  lastUsedAt    DateTime?
  expiresAt     DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime
  teams         teams?    @relation(fields: [teamId], references: [id], onDelete: Cascade)
  users         users?    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([key])
  @@index([teamId])
  @@index([userId])
}

model branding {
  id             String   @id
  teamId         String   @unique
  logoUrl        String?
  primaryColor   String   @default("#F97316")
  secondaryColor String?  @default("#FFFFFF")
  accentColor    String?
  invoicePrefix  String?  @default("INV")
  receiptPrefix  String?  @default("RCP")
  showLogo       Boolean  @default(true)
  showColors     Boolean  @default(true)
  emailFromName  String?
  emailReplyTo   String?
  customDomain   String?  @unique
  domainVerified Boolean  @default(false)
  fontFamily     String?  @default("inter")
  createdAt      DateTime @default(now())
  updatedAt      DateTime
  teams          teams    @relation(fields: [teamId], references: [id], onDelete: Cascade)
}

model clients {
  id        String     @id
  userId    String
  name      String
  email     String
  phone     String?
  address   String?
  company   String?
  taxId     String?
  website   String?
  createdAt DateTime   @default(now())
  updatedAt DateTime
  teamId    String?
  teams     teams?     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  users     users      @relation(fields: [userId], references: [id], onDelete: Cascade)
  invoices  invoices[]

  @@index([teamId])
  @@index([userId])
  @@index([email])
}

model email_templates {
  id        String   @id
  name      String   @unique
  subject   String
  body      String
  variables Json?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime
}

model invoice_items {
  id          String   @id
  invoiceId   String
  description String
  quantity    Int
  price       Float
  taxRate     Float    @default(11)
  subtotal    Float
  invoices    invoices @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([invoiceId])
}

model invoice_templates {
  id                      String           @id
  userId                  String
  name                    String
  description             String?
  taxRate                 Float            @default(11)
  notes                   String?
  createdAt               DateTime         @default(now())
  updatedAt               DateTime
  teamId                  String?
  additionalDiscountType  String?
  additionalDiscountValue Float?
  defaultClientId         String?
  discountType            String?
  discountValue           Float?
  settings                Json?
  signatoryName           String?
  signatoryTitle          String?
  signatureUrl            String?
  termsAndConditions      String?
  teams                   teams?           @relation(fields: [teamId], references: [id], onDelete: Cascade)
  users                   users            @relation(fields: [userId], references: [id], onDelete: Cascade)
  template_items          template_items[]

  @@index([teamId])
  @@index([userId])
}

model invoices {
  id                       String          @id
  userId                   String
  invoiceNumber            String          @unique
  date                     DateTime
  dueDate                  DateTime?
  accessToken              String          @unique
  companyName              String
  companyEmail             String
  companyPhone             String?
  companyAddress           String?
  clientName               String
  clientEmail              String
  clientPhone              String?
  clientAddress            String?
  notes                    String?
  taxRate                  Float           @default(11)
  subtotal                 Float
  taxAmount                Float
  total                    Float
  status                   InvoiceStatus   @default(DRAFT)
  paidAt                   DateTime?
  sentAt                   DateTime?
  viewedAt                 DateTime?
  viewCount                Int             @default(0)
  reminderCount            Int             @default(0)
  lastReminderAt           DateTime?
  createdAt                DateTime        @default(now())
  updatedAt                DateTime
  clientId                 String?
  paymentMethod            String?
  paymentNotes             String?
  teamId                   String?
  additionalDiscountAmount Float?
  additionalDiscountType   String?
  additionalDiscountValue  Float?
  discountAmount           Float?
  discountType             String?
  discountValue            Float?
  settings                 Json?
  signatoryName            String?
  signatoryTitle           String?
  signatureUrl             String?
  termsAndConditions       String?
  invoice_items            invoice_items[]
  payments                 payments[]
  clients                  clients?        @relation(fields: [clientId], references: [id])
  teams                    teams?          @relation(fields: [teamId], references: [id], onDelete: Cascade)
  users                    users           @relation(fields: [userId], references: [id], onDelete: Cascade)
  client_invoice_access    client_invoice_access[]
  invoice_messages         invoice_messages[]

  @@index([accessToken])
  @@index([status])
  @@index([teamId])
  @@index([userId])
  @@index([sentAt])
  @@index([viewedAt])
}

model items {
  id          String   @id
  userId      String
  name        String
  description String?
  sku         String?  @unique
  unit        String   @default("pcs")
  price       Float
  taxRate     Float    @default(11)
  category    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime
  teamId      String?
  teams       teams?   @relation(fields: [teamId], references: [id], onDelete: Cascade)
  users       users    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([sku])
  @@index([teamId])
  @@index([userId])
}

model payments {
  id                    String        @id
  userId                String
  invoiceId             String?
  stripePaymentId       String?       @unique
  amount                Float
  currency              String        @default("IDR")
  status                PaymentStatus
  refundedAt            DateTime?
  refundReason          String?
  createdAt             DateTime      @default(now())
  receiptNumber         String?       @unique
  receiptUrl            String?
  description           String?
  stripePaymentIntentId String?       @unique
  ewalletType           String?
  expiredAt             DateTime?
  midtransOrderId       String?       @unique
  midtransTransactionId String?
  dokuOrderId           String?       @unique
  dokuTransactionId     String?
  paymentGateway        String?
  paymentMethod         String?
  pricingPlanId         String?
  qrisUrl               String?
  paymentUrl            String?
  qrString              String?
  updatedAt             DateTime
  vaBank                String?
  vaNumber              String?
  metadata              Json?
  invoices              invoices?     @relation(fields: [invoiceId], references: [id], onDelete: SetNull)
  users                 users         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([invoiceId])
  @@index([dokuOrderId])
  @@index([midtransOrderId])
  @@index([pricingPlanId])
  @@index([status])
  @@index([stripePaymentIntentId])
  @@index([userId])
}

model rate_limit_entries {
  id        String   @id
  key       String   @unique
  count     Int      @default(1)
  resetAt   DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime

  @@index([key])
  @@index([resetAt])
}

model sessions {
  id           String   @id @default(uuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  users        users    @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model subscriptions {
  id                     String             @id
  userId                 String             @unique
  stripeCustomerId       String?            @unique
  stripeSubscriptionId   String?            @unique
  stripePriceId          String?
  stripeCurrentPeriodEnd DateTime?
  status                 SubscriptionStatus @default(FREE)
  planType               PlanType           @default(FREE)
  pricingPlanId          String?
  createdAt              DateTime           @default(now())
  updatedAt              DateTime
  trialEndsAt            DateTime?
  trialSentReminder      Boolean            @default(false)
  trialStartsAt          DateTime?
  users                  users              @relation(fields: [userId], references: [id], onDelete: Cascade)
  pricing_plans          pricing_plans?     @relation(fields: [pricingPlanId], references: [id], onDelete: SetNull)

  @@index([trialEndsAt])
  @@index([pricingPlanId])
}

model team_invitations {
  id        String           @id
  teamId    String
  email     String
  role      TeamRole         @default(MEMBER)
  token     String           @unique
  invitedBy String
  status    InvitationStatus @default(PENDING)
  expiresAt DateTime
  createdAt DateTime         @default(now())
  updatedAt DateTime
  teams     teams            @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@index([email])
  @@index([teamId])
  @@index([token])
}

model team_members {
  id          String   @id
  teamId      String
  userId      String
  role        TeamRole @default(MEMBER)
  permissions Json?
  invitedBy   String?
  joinedAt    DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime
  teams       teams    @relation(fields: [teamId], references: [id], onDelete: Cascade)
  users       users    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([teamId, userId])
  @@index([teamId])
  @@index([userId])
}

model teams {
  id                     String              @id
  name                   String
  slug                   String              @unique
  description            String?
  ownerId                String
  planType               PlanType            @default(FREE)
  stripeCustomerId       String?             @unique
  stripeSubscriptionId   String?             @unique
  stripePriceId          String?
  stripeCurrentPeriodEnd DateTime?
  settings               Json?
  createdAt              DateTime            @default(now())
  updatedAt              DateTime
  api_keys               api_keys[]
  branding               branding?
  clients                clients[]
  invoice_templates      invoice_templates[]
  invoices               invoices[]
  items                  items[]
  team_invitations       team_invitations[]
  team_members           team_members[]
  users                  users               @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  webhooks               webhooks[]

  @@index([ownerId])
  @@index([slug])
}

model template_items {
  id                String            @id
  templateId        String
  description       String
  quantity          Int
  price             Float
  invoice_templates invoice_templates @relation(fields: [templateId], references: [id], onDelete: Cascade)
}

model users {
  id                   String              @id @default(uuid())
  name                 String?
  email                String              @unique
  emailVerified        DateTime?
  image                String?
  password             String?
  createdAt            DateTime            @default(now())
  updatedAt            DateTime
  companyAddress       String?
  companyEmail         String?
  companyName          String?
  companyPhone         String?
  smtpHost             String?
  smtpPass             String?
  smtpPort             String?             @default("587")
  smtpSecure           Boolean?            @default(false)
  smtpUser             String?
  activeTeamId         String?
  twoFactorBackupCodes String?
  twoFactorEnabled     Boolean             @default(false)
  twoFactorSecret      String?
  twoFactorVerifiedAt  DateTime?
  accounts             accounts[]
  activity_logs        activity_logs[]
  api_keys             api_keys[]
  clients              clients[]
  invoice_templates    invoice_templates[]
  invoices             invoices[]
  items                items[]
  payments             payments[]
  sessions             sessions[]
  subscriptions        subscriptions?
  team_members         team_members[]
  teams                teams[]
  // Micro-SaaS relations
  announcement_reads   announcement_reads[]
  support_tickets      support_tickets[]
  support_messages     support_messages[]
  impersonation_sessions impersonation_sessions[]
}

model verification_tokens {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model webhooks {
  id            String    @id
  teamId        String
  name          String
  url           String
  secret        String
  events        Json
  isActive      Boolean   @default(true)
  lastTriggered DateTime?
  failureCount  Int       @default(0)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime
  teams         teams     @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@index([teamId])
}

enum ActivityAction {
  CREATED
  UPDATED
  DELETED
  SENT
  PAID
  OVERDUE
  CANCELED
  REMINDED
  VIEWED
  PAYMENT_REFUNDED
  PAYMENT_STATUS_CHANGED
  PAYMENT_DELETED
  MANUAL_PAYMENT_CREATED
  REMINDER_SENT
  OVERDUE_NOTICE_SENT
}

enum InvitationStatus {
  PENDING
  ACCEPTED
  DECLINED
  EXPIRED
}

enum InvoiceStatus {
  DRAFT
  SENT
  PAID
  OVERDUE
  CANCELED
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

enum PlanType {
  FREE
  PRO
}

model pricing_plans {
  id            String   @id @default(uuid())
  name          String
  slug          String   @unique
  description   String?
  price         Float    @default(0)
  currency      String   @default("IDR")
  stripePriceId String?  @unique
  trialDays     Int      @default(0)
  isFeatured    Boolean  @default(false)
  isActive      Boolean  @default(true)
  sortOrder     Int      @default(0)
  ctaText       String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  features      pricing_plan_features[]
  subscriptions subscriptions[]

  @@index([isActive, sortOrder])
}

model pricing_features {
  id          String   @id @default(uuid())
  name        String
  key         String   @unique
  description String?
  sortOrder   Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  plans       pricing_plan_features[]

  @@index([isActive, sortOrder])
}

model pricing_plan_features {
  planId    String
  featureId String
  included  Boolean @default(true)
  limitValue Int?
  plan      pricing_plans    @relation(fields: [planId], references: [id], onDelete: Cascade)
  feature   pricing_features @relation(fields: [featureId], references: [id], onDelete: Cascade)

  @@id([planId, featureId])
  @@index([planId])
  @@index([featureId])
}

enum SubscriptionStatus {
  ACTIVE
  CANCELED
  PAST_DUE
  TRIALING
  INCOMPLETE
  INCOMPLETE_EXPIRED
  FREE
}

enum TeamRole {
  OWNER
  ADMIN
  MEMBER
  VIEWER
}

// ==================== Micro-SaaS Tables ====================

model announcements {
  id           String   @id @default(uuid())
  title        String
  message      String
  type         String   @default("info") // "info", "warning", "success", "error"
  targetType   String   @default("all")  // "all", "free", "pro", "specific"
  targetUsers  Json?    // Array of user IDs for specific targeting
  displayType  String   @default("banner") // "banner", "modal", "toast"
  isDismissible Boolean @default(true)
  isActive     Boolean  @default(true)
  startsAt     DateTime?
  endsAt       DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  announcement_reads announcement_reads[]

  @@index([isActive, startsAt, endsAt])
}

model announcement_reads {
  id             String       @id @default(uuid())
  announcementId String
  userId         String
  readAt         DateTime     @default(now())
  dismissedAt    DateTime?
  announcements  announcements @relation(fields: [announcementId], references: [id], onDelete: Cascade)
  users          users        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([announcementId, userId])
  @@index([announcementId])
  @@index([userId])
}

model support_tickets {
  id          String   @id @default(uuid())
  userId      String?  // Optional - for vendor/user tickets
  clientId    String?  // For client tickets
  subject     String
  description String
  category    String   @default("general") // "general", "billing", "technical", "feature_request"
  priority    String   @default("normal")  // "low", "normal", "high", "urgent"
  status      String   @default("open")    // "open", "in_progress", "waiting_customer", "resolved", "closed"
  assignedTo  String?  // Admin ID
  lastReplyAt DateTime?
  resolvedAt  DateTime?
  closedAt    DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  users       users?   @relation(fields: [userId], references: [id], onDelete: Cascade)
  client      client_accounts? @relation(fields: [clientId], references: [id], onDelete: Cascade)
  support_messages support_messages[]

  @@index([userId])
  @@index([clientId])
  @@index([status])
  @@index([assignedTo])
  @@index([createdAt])
}

model support_messages {
  id        String   @id @default(uuid())
  ticketId  String
  userId    String?
  adminId   String?
  clientId  String?  // For client replies
  message   String
  isInternal Boolean @default(false) // For internal notes not visible to user
  attachments Json?  // Array of attachment URLs
  createdAt DateTime @default(now())
  support_tickets support_tickets @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  users     users?   @relation(fields: [userId], references: [id], onDelete: SetNull)
  client    client_accounts? @relation(fields: [clientId], references: [id], onDelete: SetNull)

  @@index([ticketId])
  @@index([clientId])
  @@index([createdAt])
}

model impersonation_sessions {
  id           String   @id @default(uuid())
  adminId      String
  targetUserId String
  token        String   @unique
  reason       String?
  endedAt      DateTime?
  endReason    String?
  createdAt    DateTime @default(now())
  admins       admins   @relation(fields: [adminId], references: [id], onDelete: Cascade)
  users        users    @relation(fields: [targetUserId], references: [id], onDelete: Cascade)

  @@index([adminId])
  @@index([targetUserId])
  @@index([token])
  @@index([createdAt])
}

// ==================== Client Dashboard Tables ====================

// Client Account - for clients who want to register for dashboard access
model client_accounts {
  id                     String                     @id @default(uuid())
  email                  String                     @unique
  name                   String
  phone                  String?
  password               String?                    // hashed password (optional for magic link)
  magicLinkToken         String?                    @unique
  magicLinkExpires       DateTime?
  createdAt              DateTime                   @default(now())
  updatedAt              DateTime                   @updatedAt
  client_invoice_access      client_invoice_access[]
  client_notifications       client_notifications[]
  client_notification_preferences client_notification_preferences?
  invoice_messages           invoice_messages[]
  support_tickets            support_tickets[]
  support_messages           support_messages[]

  @@index([email])
  @@index([magicLinkToken])
}

// Link between invoice and client account for access tracking
model client_invoice_access {
  id          String         @id @default(uuid())
  clientId    String
  invoiceId   String
  accessToken String         @unique // token unik untuk akses
  lastViewed  DateTime?
  viewCount   Int            @default(0)
  client      client_accounts @relation(fields: [clientId], references: [id], onDelete: Cascade)
  invoice     invoices       @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  createdAt   DateTime       @default(now())

  @@unique([clientId, invoiceId])
  @@index([clientId])
  @@index([invoiceId])
  @@index([accessToken])
}

// Notifications for clients
model client_notifications {
  id          String         @id @default(uuid())
  clientId    String
  type        String         // "invoice_sent", "payment_reminder", "payment_received", "overdue", "message", "system"
  title       String
  message     String
  data        Json?          // data tambahan (invoice id, dll)
  isRead      Boolean        @default(false)
  readAt      DateTime?
  client      client_accounts @relation(fields: [clientId], references: [id], onDelete: Cascade)
  createdAt   DateTime       @default(now())

  @@index([clientId, isRead])
  @@index([clientId, createdAt])
  @@index([type])
}

// Client notification preferences
model client_notification_preferences {
  id                String         @id @default(uuid())
  clientId          String         @unique
  emailNotification Boolean        @default(true)
  invoiceSent       Boolean        @default(true)
  paymentReminder   Boolean        @default(true)
  paymentReceived   Boolean        @default(true)
  overdueAlert      Boolean        @default(true)
  newMessage        Boolean        @default(true)
  client            client_accounts @relation(fields: [clientId], references: [id], onDelete: Cascade)
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
}

// Messages/Comments on invoices
model invoice_messages {
  id          String         @id @default(uuid())
  invoiceId   String
  senderType  String         // "vendor" atau "client"
  senderId    String         // user id atau client id
  message     String
  attachments Json?          // array of URLs
  isRead      Boolean        @default(false)
  invoice     invoices       @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  sender      client_accounts? @relation(fields: [senderId], references: [id], onDelete: SetNull)
  createdAt   DateTime       @default(now())

  @@index([invoiceId, createdAt])
  @@index([senderType, senderId])
}
