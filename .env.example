# ===========================================
# InvoiceKirim Environment Variables
# ===========================================
# Copy this file to .env.local and fill in your values
# Required variables are marked with [REQUIRED]
# ===========================================

# ===========================================
# Database [REQUIRED]
# ===========================================
# PostgreSQL database connection URL
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="postgresql://user:password@localhost:5432/invoicekirim"

# ===========================================
# NextAuth Configuration [REQUIRED]
# ===========================================
# The canonical URL of your application
# Development: http://localhost:3000
# Production: https://yourdomain.com
NEXTAUTH_URL="http://localhost:3000"

# Secret key for NextAuth.js JWT encryption
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="your-secret-here-generate-with-openssl-rand-base64-32"

# ===========================================
# Application URL [REQUIRED]
# ===========================================
# Public URL of your application (used for links in emails, etc.)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ===========================================
# Stripe Payment Gateway (Optional)
# ===========================================
# Get your keys from: https://dashboard.stripe.com/apikeys
# Test key starts with sk_test_, Live key starts with sk_live_
STRIPE_SECRET_KEY="sk_test_your-stripe-secret-key"

# Webhook secret from Stripe Dashboard > Webhooks
# Starts with whsec_
STRIPE_WEBHOOK_SECRET="whsec_your-webhook-secret"

# Price ID for PRO subscription
# Create in Stripe Dashboard > Products
STRIPE_PRO_PRICE_ID="price_your-price-id"
STRIPE_PRO_MONTHLY_PRICE_ID="price_your-monthly-price-id"

# ===========================================
# Google OAuth (Optional)
# ===========================================
# Get credentials from: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID="your-google-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# ===========================================
# Email Service - Resend (Optional)
# ===========================================
# Get your API key from: https://resend.com/api-keys
# Required for sending invoice emails and notifications
RESEND_API_KEY="re_your-resend-api-key"

# ===========================================
# Cron Job Security (Recommended)
# ===========================================
# Secret key to secure cron job endpoints
# Generate with: openssl rand -hex 32
CRON_SECRET="your-cron-secret-here"

# ===========================================
# Rate Limiting - Upstash Redis (Optional)
# ===========================================
# Get credentials from: https://upstash.com
# Required for production rate limiting
UPSTASH_REDIS_REST_URL="https://your-redis-url.upstash.io"
UPSTASH_REDIS_REST_TOKEN="your-upstash-token"

# ===========================================
# Duitku Payment Gateway - Indonesia
# ===========================================
# Get credentials from: https://dashboard.duitku.com/
# Register for sandbox account first to get test credentials
DUITKU_MERCHANT_CODE="your-merchant-code"
DUITKU_API_KEY="your-api-key"
DUITKU_MODE="SANDBOX"  # Use "SANDBOX" for testing, "PRODUCTION" for live

# ===========================================
# Development Settings
# ===========================================
# Set to 'true' to throw errors on missing env vars during development
STRICT_ENV_CHECK="false"
